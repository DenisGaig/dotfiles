{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "checkThirdParty": false,
    "maxPreload": 5000,
    "preloadFileSize": 300,
    "library": [
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/LuaSnip/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/blink.cmp/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/diffview.nvim/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/flash.nvim/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.bufremove/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.clue/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.extra/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.files/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.pick/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/neocodeium/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/nvim-autopairs/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/nvim-treesitter/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/nvim-treesitter-context/lua"

    ]
  }
}
